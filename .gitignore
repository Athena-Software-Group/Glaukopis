# Athena Bench scrape / processing outputs.
# These were previously tracked as Git LFS pointer files but most of the
# backing LFS objects are missing from the server (404 on 'git lfs pull').
# The benchmark runner does not depend on this directory; it is only used
# for regenerating datasets via the scraping pipelines.
SFT/test/data/processed/
SFT/test/data/raw/


# tmpl_gen triple-generation artifacts (intermediate JSONs, merged triples,
# rendered templates, per-run logs). Source lives in tmpl_gen/templates/;
# outputs are regenerated by utils/generate_triples.sh on demand.
tmpl_gen/utils/output-*/
tmpl_gen/utils/_db_schema.json

tmpl_gen/data_generation/

SFT/test/responses/

*.safetensors

SFT/merged/

# CPT pipeline: raw fetched artifacts and intermediate parsed JSONL are
# regeneratable via cpt/build_corpus.py; built corpus JSONLs are large
# and stay on the training host (transferred via rsync like SFT ift_data_*.json).
cpt/cache/
cpt/corpus/
SFT/data/
SFT/test/responses/

# CyberSOCEval (CrowdStrike + Meta) data: cloned repo + downloaded PDFs +
# extracted text files. Regenerable via SFT/test/utils/fetch_cybersoceval_data.py.
SFT/test/benchmark_data/cybersoceval/
