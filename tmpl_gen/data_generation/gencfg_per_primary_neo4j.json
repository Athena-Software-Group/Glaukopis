{
    "version": "0.0",
    "default_propname": "name",
    "default_count_limit": 10,
    "default_order_by": "none",
    "override_order_by": "random",
    "list_property_separator": ", ",
    "inverse_relationships": {
        "used-by": "uses",
        "used_by": "uses",
        "attributed_by": "attributed-to",
        "revokes": "revoked-by",
