# Credentials used by prepare_dataset.sh, train.sh, and run_athenabench.sh.
#
# Copy this file to `.env` (same directory) and fill in real values:
#   cp SFT/autotrain/.env.example SFT/autotrain/.env
#   chmod 600 SFT/autotrain/.env    # recommended
#
# The `.env` file is gitignored; this `.env.example` template is committed
# to show the required variables.

# Hugging Face write-scope token. Create one at
# https://huggingface.co/settings/tokens (Role: write).
export HF_TOKEN=hf_xxx_replace_me

# Hugging Face username (or org) that will own the pushed dataset and model.
export HF_USERNAME=your-hf-username
