# Credentials used by the SFT pipeline (utils/run_train.sh, upload_to_hf.py,
# autotrain/run_abaligned_sft.sh, autotrain/run_athenabench.sh).
#
# Copy this file to `.env` (same directory) and fill in real values:
#   cp SFT/.env.example SFT/.env
#   chmod 600 SFT/.env    # recommended
#
# The `.env` file is gitignored; this `.env.example` template is committed.
# SFT/utils/setup.sh auto-creates `.env` from this template on first run.

# --- Hugging Face Hub --------------------------------------------------------

# Write-scope token. Create at https://huggingface.co/settings/tokens
export HF_TOKEN=hf_xxx_replace_me

# HF username (or org) that will own the pushed dataset and model.
# NOTE: this is the HF handle, NOT your email address.
export HF_USERNAME=your-hf-username

# --- Weights & Biases (for --report-to wandb) --------------------------------

# API key. Copy from https://wandb.ai/authorize
export WANDB_API_KEY=wandb_xxx_replace_me

# Project name on wandb; new runs are auto-created under this project.
# Leave the default unless you want a different grouping.
export WANDB_PROJECT=athena-cti-sft

# (Optional) entity (team/org). Leave unset to use your default personal entity.
# export WANDB_ENTITY=your-team-or-org

# --- Git identity (used by SFT/utils/setup.sh) -------------------------------
#
# When both values are present, setup.sh runs:
#   git config --global user.name  "$GIT_USER_NAME"
#   git config --global user.email "$GIT_USER_EMAIL"
# so fresh boxes (containers, EC2 spot, Modal, RunPod, Jarvis Labs, etc.) get
# a usable identity without a manual `git config` step. Leave commented to
# preserve any existing global identity on the box.
# export GIT_USER_NAME="Your Name"
# export GIT_USER_EMAIL=you@example.com
